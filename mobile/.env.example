# Override the API base URL used by the app (optional).
# For Expo/React Native the app reads `EXPO_PUBLIC_API_BASE_URL`.
# Examples:
#  - Android emulator (Android Studio): EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:5000/api
#  - iOS simulator:                         EXPO_PUBLIC_API_BASE_URL=http://localhost:5000/api
#  - Physical device: use your machine LAN IP: http://192.168.x.y:5000/api
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000/api
